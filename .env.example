# OpenBlend Public Environment Example
# Copy this file to .env and fill in your API keys

# Premium main model API key (required if you use baosi-claude)
# BAOSI_API_KEY=sk-xxx

# Kilo Gateway API key (required for free models from Kilo)
# Get one at https://kilo.ai/
# KILO_API_KEY=your-kilo-api-key

# OpenRouter API key (required for free models from OpenRouter)
# Get one at https://openrouter.ai/
# OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Optional: Require API key for accessing the OpenBlend server
# BLEND_API_ACCESS_KEY=your-server-access-key
